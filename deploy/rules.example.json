[
  {
    "name": "secret-read",
    "pattern": "^READ .*(secret|token|credential|password|shadow|wallet|\\.pem|\\.key|\\.aws|\\.ssh|\\.npmrc|\\.env|id_rsa)",
    "always_on": true
  },
  {
    "name": "cloud-metadata",
    "pattern": "^CONNECT 169\\.254\\.169\\.254:",
    "always_on": true
  },
  {
    "name": "new-outbound-connect",
    "pattern": "^CONNECT ",
    "exclude": []
  },
  {
    "name": "new-exec",
    "pattern": "^EXEC ",
    "exclude": []
  }
]
